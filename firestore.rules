rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ──────────────────────────────────────────────
    // Get the authenticated user's profile document
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Check if the caller is a member of the project and return their role
    function getProjectRole(projectId) {
      let project = get(/databases/$(database)/documents/projects/$(projectId)).data;
      return project.members[request.auth.uid].role;
    }

    // Check if user is a member of the project at all
    function isProjectMember(projectId) {
      let project = get(/databases/$(database)/documents/projects/$(projectId)).data;
      return request.auth.uid in project.members;
    }

    // Check if user belongs to the same organization as the project
    function isInProjectOrg(data) {
      return request.auth != null && data.organizationId == getUserDoc().organizationId;
    }

    // Role hierarchy checks — returns true if user's project role is in the allowed set
    function hasRole(projectId, allowedRoles) {
      return isProjectMember(projectId) && (getProjectRole(projectId) in allowedRoles);
    }

    // Check if the project is closed
    function isProjectClosed(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)).data.status in ['closed_won', 'closed_lost'];
    }

    // ─── Organizations ─────────────────────────────────────────────────
    // Only the organization owner can write; members can read their own org.
    match /organizations/{orgId} {
      allow read: if request.auth != null
                  && getUserDoc().organizationId == orgId;
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid;
      allow delete: if false; // Orgs are never client-deleted
    }

    // ─── Users ─────────────────────────────────────────────────────────
    // Users can read/write their own profile. No cross-user reads.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false; // User docs are never client-deleted
    }

    // ─── Projects ──────────────────────────────────────────────────────
    // Only project members within the same org can read.
    // Only Lead Investor and General Contractor can write.
    // Only Lead Investor can delete.
    match /projects/{projectId} {
      allow read: if request.auth != null
                  && isInProjectOrg(resource.data);

      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;

      allow update: if request.auth != null
                    && hasRole(projectId, ['Lead Investor', 'General Contractor'])
                    && isInProjectOrg(resource.data)
                    && !isProjectClosed(projectId);

      allow delete: if request.auth != null
                    && hasRole(projectId, ['Lead Investor'])
                    && !isProjectClosed(projectId);

      // ─── Ledger Items (Sub-Collection) ─────────────────────────────
      // All project members can read. Only finance-authorized roles can write.
      match /ledgerItems/{itemId} {
        allow read: if request.auth != null
                    && isInProjectOrg(get(/databases/$(database)/documents/projects/$(projectId)).data);

        // Lead Investor, General Contractor, and Accountant can create items
        allow create: if request.auth != null
                      && hasRole(projectId, ['Lead Investor', 'General Contractor', 'Accountant'])
                      && request.resource.data.organizationId == getUserDoc().organizationId
                      && !isProjectClosed(projectId);

        // Only Lead Investor and Accountant can approve/reject (update)
        allow update: if request.auth != null
                      && hasRole(projectId, ['Lead Investor', 'Accountant'])
                      && !isProjectClosed(projectId);

        // Only Lead Investor can delete ledger items
        allow delete: if request.auth != null
                      && hasRole(projectId, ['Lead Investor'])
                      && !isProjectClosed(projectId);
      }

      // ─── Phase Snapshots (Sub-Collection) ──────────────────────────
      // Snapshots are immutable once captured to preserve historical accuracy.
      match /phaseSnapshots/{phaseKey} {
        allow read: if request.auth != null
                    && isInProjectOrg(get(/databases/$(database)/documents/projects/$(projectId)).data);

        // Allow Lead Investor to create a snapshot, but not update or delete it
        allow create: if request.auth != null
                      && hasRole(projectId, ['Lead Investor'])
                      && !isProjectClosed(projectId);

        allow update, delete: if false;
      }

      // ─── Private Financials (Sub-Collection) ───────────────────────
      // This is the True Field-Level Security workaround.
      // Only Lead Investor, Accountant, and Lender can read.
      // Only server-side (Admin SDK) should write — but we allow Lead Investor
      // as a fallback for the Engine Room recalculation.
      match /privateFinancials/{docId} {
        allow read: if request.auth != null
                    && isInProjectOrg(get(/databases/$(database)/documents/projects/$(projectId)).data);

        allow write: if request.auth != null
                     && hasRole(projectId, ['Lead Investor'])
                     && !isProjectClosed(projectId);
      }
    }

    // ─── Waitlist (Landing Page Lead Capture) ──────────────────────────
    // Anyone can add their email; nobody can read/update/delete.
    match /waitlist/{entryId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // ─── Audit Log ─────────────────────────────────────────────────────
    // Immutable append-only log. Only server should write, but we allow
    // authenticated creates. No reads, updates, or deletes from client.
    match /auditLog/{logId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // ─── Default: Deny All ─────────────────────────────────────────────
    // Any collection not explicitly matched above is locked.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
